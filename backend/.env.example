# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=insurance_copilot

# AWS S3 / MinIO (leave S3_ENDPOINT_URL blank for real AWS)
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=insurance-documents
S3_ENDPOINT_URL=

# LLM API (OpenAI/Azure/etc) — base URL without /chat/completions, it's appended automatically
LLM_API_KEY=your_llm_api_key
LLM_API_BASE_URL=https://api.openai.com/v1

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:5173

# Application
APP_ENV=development
LOG_LEVEL=INFO

# Concurrency (optional; reduce to avoid OOM / CPU oversubscription)
OCR_MAX_WORKERS=2
FACE_MATCH_MAX_WORKERS=1
OMP_NUM_THREADS=1

GOOGLE_MAPS_API_KEY=your_google_maps_api_key

USE_OPENROUTER=0
OPENROUTER_API_KEY=sk-or-v1-your-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=qwen/qwen3.5-27b

LLM_CONCURRENCY_QWEN35_27B=4
LLM_CONCURRENCY_GPT_OSS_120B=4